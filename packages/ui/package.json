{
  "name": "@ui",
  "version": "1.0.0",
  "type": "module",
  "sideEffects": [
    "**/*.css.ts",
    "**/styles/index.ts"
  ],
  "main": "./src/index.ts",
  "types": "./dist-types/index.d.ts",
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc -b",
    "format": "prettier src --write --ignore-path ../../.prettierignore",
    "format:check": "prettier src --check --ignore-path ../../.prettierignore",
    "clean": "rm -rf dist-types node_modules"
  },
  "peerDependencies": {
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "2.28.0",
    "react-native-reanimated": "4.1.7",
    "react-native-safe-area-context": "5.6.2",
    "react-native-theme-switch-animation": "0.8.0",
    "react-native-edge-to-edge": "1.8.1",
    "react-native-worklets": "0.8.1",
    "@vanilla-extract/css": "1.17.4",
    "@vanilla-extract/recipes": "0.5.7",
    "@vanilla-extract/sprinkles": "1.6.5",
    "clsx": "2.1.1",
    "lucide-react": "0.575.0",
    "lucide-react-native": "0.575.0"
  },
  "devDependencies": {
    "@types/react": "19.1.17",
    "typescript": "5.9.3"
  },
  "exports": {
    ".": {
      "react-native": {
        "types": "./dist-types/index.native.d.ts",
        "default": "./src/index.native.ts"
      },
      "types": "./dist-types/index.d.ts",
      "default": "./src/index.ts"
    }
  }
}
