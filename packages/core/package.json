{
  "name": "@core",
  "version": "1.0.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./dist-types/index.d.ts",
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc -b",
    "format": "prettier src --write --ignore-path ../../.prettierignore",
    "format:check": "prettier src --check --ignore-path ../../.prettierignore",
    "clean": "rm -rf dist-types node_modules"
  },
  "peerDependencies": {
    "@tanstack/react-query": "5.90.18",
    "react": "19.1.0",
    "zustand": "5.0.10"
  },
  "devDependencies": {
    "@types/react": "19.1.17",
    "typescript": "5.9.3"
  },
  "exports": {
    ".": {
      "types": "./dist-types/index.d.ts",
      "default": "./src/index.ts"
    }
  }
}
