{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["eslint.config.ts", "tsconfig.base.json"],
  "globalPassThroughEnv": ["WEB_PORT", "RCT_METRO_PORT"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {},
    "lint": {},
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": ["dist-types/**"]
    },
    "format": {
      "cache": false
    },
    "format:check": {
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
